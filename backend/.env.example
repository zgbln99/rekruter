APP_NAME=Rekruter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- PostgreSQL ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=rekruter
DB_USERNAME=rekruter
DB_PASSWORD=secret

# --- Sesje / cache / kolejki (Redis) ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Poczta (SMTP / Mailpit w dev) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="rekrutacja@rekruter.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3 / Storage (dev: MinIO, dysk "s3") ---
AWS_ACCESS_KEY_ID=rekruter
AWS_SECRET_ACCESS_KEY=rekruter-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=rekruter
AWS_ENDPOINT=http://minio:9000
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Dysk dokumentów kandydatów ---
# dev: local; prod (MinIO): s3; docelowo: mega_s3
DOCUMENTS_DISK=s3

# --- MEGA S4 (dysk "mega_s3" — docelowy storage dokumentów) ---
# Ustaw DOCUMENTS_DISK=mega_s3. Klucz/sekret możesz podać tutaj (MEGA_S4_*)
# LUB — jeśli masz tylko sloty AWS_* — wpisać klucze MEGA do AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY (dysk mega_s3 użyje ich jako fallback). Endpoint/bucket/region
# mają już domyślne wartości MEGA S4 (poniżej tylko dla referencji/nadpisania).
MEGA_S4_ACCESS_KEY_ID=
MEGA_S4_SECRET_ACCESS_KEY=
MEGA_S4_BUCKET=driver-ddd-files
MEGA_S4_ENDPOINT=https://s3.eu-luxembourg.megas4.com
MEGA_S4_REGION=eu-amsterdam
MEGA_S4_USE_PATH_STYLE_ENDPOINT=true

# --- Sanctum / CORS ---
SANCTUM_STATEFUL_DOMAINS=localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Gotenberg (HTML -> PDF) ---
GOTENBERG_URL=http://gotenberg:3000
