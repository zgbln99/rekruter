# syntax=docker/dockerfile:1
# Produkcyjny obraz frontendu: statyczna PWA serwowana przez nginx,
# z proxy /api do backendu (php-fpm). Używany przez docker-compose.prod.yml.

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
# Bazowy adres API jako ścieżka względna (ten sam origin co frontend).
ARG NUXT_PUBLIC_API_BASE=/api/v1
ENV NUXT_PUBLIC_API_BASE=$NUXT_PUBLIC_API_BASE
RUN npm run generate

FROM nginx:1.27-alpine AS runtime
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/.output/public /usr/share/nginx/html
EXPOSE 80
