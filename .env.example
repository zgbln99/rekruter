# Zmienne dla docker-compose (poziom root). Skopiuj: cp .env.example .env
# Backend czyta własny ./backend/.env (skopiuj z ./backend/.env.example).

DB_DATABASE=rekruter
DB_USERNAME=rekruter
DB_PASSWORD=secret

AWS_ACCESS_KEY_ID=rekruter
AWS_SECRET_ACCESS_KEY=rekruter-secret
AWS_BUCKET=rekruter

# --- Storage dokumentów ---
# s3 = wbudowane MinIO (domyślnie). mega_s3 = MEGA S4 (uzupełnij klucze poniżej).
DOCUMENTS_DISK=s3

# --- MEGA S4 (gdy DOCUMENTS_DISK=mega_s3) ---
# Wpisz klucze z panelu MEGA S4. Endpoint/bucket/region mają już wartości domyślne.
MEGA_S4_ACCESS_KEY_ID=
MEGA_S4_SECRET_ACCESS_KEY=
MEGA_S4_BUCKET=driver-ddd-files
MEGA_S4_ENDPOINT=https://s3.eu-luxembourg.megas4.com
MEGA_S4_REGION=eu-amsterdam

NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
